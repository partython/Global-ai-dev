# =====================================================
# Priya Global Platform - Environment Configuration
# Copy this to .env and fill in your values
# =====================================================

ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
PLATFORM_NAME=Priya AI

# ─── PostgreSQL (Aurora in production) ───
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=priya_global
PG_USER=priya_admin
PG_PASSWORD=your_secure_password_here
PG_POOL_MIN=2
PG_POOL_MAX=20
PG_SSL_MODE=prefer

# ─── Redis (ElastiCache in production) ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1
REDIS_SSL=false

# ─── JWT (Generate RS256 keypair: openssl genrsa -out private.pem 2048) ───
JWT_SECRET_KEY=your_rs256_private_key_here
JWT_PUBLIC_KEY=your_rs256_public_key_here
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800
JWT_ISSUER=priya-global

# ─── AWS ───
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
S3_BUCKET=priya-global-media
COGNITO_POOL_ID=
COGNITO_CLIENT_ID=

# ─── AI/LLM Providers ───
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key
GOOGLE_AI_KEY=your_google_ai_key
PRIMARY_LLM=claude-3-5-sonnet-20241022
SECONDARY_LLM=gpt-4o
COST_LLM=gpt-4o-mini

# ─── Stripe Billing ───
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ─── Meta (WhatsApp + Instagram + Facebook) ───
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
WHATSAPP_ACCESS_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
META_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# ─── SMS/Voice (Regional Carriers) ───
EXOTEL_SID=your_exotel_sid
EXOTEL_TOKEN=your_exotel_token
EXOTEL_ACCOUNT_SID=your_exotel_account_sid
BANDWIDTH_ACCOUNT_ID=your_bandwidth_id
BANDWIDTH_API_TOKEN=your_bandwidth_token

# ─── Shopify OAuth ───
SHOPIFY_CLIENT_ID=your_shopify_client_id
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret

# ─── WooCommerce (no client ID/secret needed — uses per-store REST API keys) ───
# WooCommerce generates consumer_key/consumer_secret per store during OAuth.
# No global credentials needed — keys are stored per-tenant in encrypted DB.

# ─── Webhook Verify Tokens ───
SOCIAL_WEBHOOK_TOKEN=your_social_webhook_verify_token

# ─── Docker Compose (REQUIRED — compose will fail without these) ───
POSTGRES_PASSWORD=your_secure_postgres_password
GRAFANA_PASSWORD=your_secure_grafana_password

# ─── Credential Encryption (AES-256 via Fernet) ───
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIALS_ENCRYPTION_KEY=your_fernet_key_here

# ─── Security ───
CORS_ORIGINS=http://localhost:3000,http://localhost:9000
