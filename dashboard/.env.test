# E2E Test Environment Variables
# Copy this file to .env.test.local for local overrides

# Base URL for tests (should match your dev server)
PLAYWRIGHT_BASE_URL=http://localhost:3000

# Test timeout (in milliseconds)
PLAYWRIGHT_TEST_TIMEOUT=30000

# Browser to use for tests
# Options: chromium, firefox, webkit
PLAYWRIGHT_BROWSER=chromium

# Run tests in headed mode (see browser)
PLAYWRIGHT_HEADED=false

# Enable debug mode
PLAYWRIGHT_DEBUG=false

# Number of retries on failure
PLAYWRIGHT_RETRIES=0

# Run tests in parallel
PLAYWRIGHT_WORKERS=auto

# Slow motion (milliseconds delay between actions)
PLAYWRIGHT_SLOW_MO=0

# Screenshot on failure
PLAYWRIGHT_SCREENSHOT=only-on-failure

# Video on failure
PLAYWRIGHT_VIDEO=retain-on-failure

# Trace on first retry
PLAYWRIGHT_TRACE=on-first-retry

# Test users (for local overrides)
TEST_USER_EMAIL=test@priya-global.com
TEST_USER_PASSWORD=SecurePass123!

# Mock API responses
MOCK_API_ENABLED=true
MOCK_API_DELAY=0

# Reporting
PLAYWRIGHT_REPORTER=html,junit
PLAYWRIGHT_JUNIT_OUTPUT=junit-results.xml

# Mobile testing
# true to run mobile tests, false to skip
PLAYWRIGHT_MOBILE_TESTS=true

# Dashboard polling interval (for auto-refresh tests)
DASHBOARD_POLL_INTERVAL=30000

# Conversation refresh interval
CONVERSATION_REFRESH_INTERVAL=5000

# Channel sync interval
CHANNEL_SYNC_INTERVAL=60000
