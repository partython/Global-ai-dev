# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=priya_global
DB_USER=postgres
DB_PASSWORD=secure_password_here

# Service Configuration
PORT=9029
HOST=0.0.0.0

# Authentication & Security
JWT_SECRET=your_jwt_secret_key_here_must_be_at_least_32_characters

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://app.example.com

# Google Calendar Integration (optional)
GOOGLE_CALENDAR_API_KEY=your_google_api_key
GOOGLE_CALENDAR_SECRET=your_google_client_secret

# Outlook Integration (optional)
OUTLOOK_CLIENT_ID=your_outlook_client_id
OUTLOOK_CLIENT_SECRET=your_outlook_client_secret

# Zoom Integration (optional)
ZOOM_API_KEY=your_zoom_api_key
ZOOM_API_SECRET=your_zoom_api_secret

# Email Configuration (for reminders)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=appointments@example.com
SMTP_PASSWORD=smtp_password_here

# Logging
LOG_LEVEL=INFO
