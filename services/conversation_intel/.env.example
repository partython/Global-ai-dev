# ================== Service Configuration ==================
CONV_INTEL_PORT=9028
SERVICE_NAME=Conversation Intelligence

# ================== Database Configuration ==================
DATABASE_URL=postgresql://conv_intel:password123@postgres:5432/aisales_prod
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20
DB_COMMAND_TIMEOUT=60

# ================== Security & JWT ==================
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256

# ================== AI/LLM APIs ==================
# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI (GPT-4)
OPENAI_API_KEY=sk-your-key-here

# ================== CORS Configuration ==================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://yourdomain.com

# ================== Feature Flags ==================
ENABLE_SENTIMENT_ANALYSIS=true
ENABLE_TOPIC_EXTRACTION=true
ENABLE_INTENT_CLASSIFICATION=true
ENABLE_COACHING_INSIGHTS=true
ENABLE_SALES_OPPORTUNITIES=true

# ================== Logging ==================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ================== Analytics ==================
ENABLE_METRICS=true
METRICS_PORT=9090
