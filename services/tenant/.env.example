# Tenant Service Configuration (.env.example)
# Copy to .env and update with your values

# ─────────────────────────────────────────────────────────────────────────────
# Database Configuration
# ─────────────────────────────────────────────────────────────────────────────

PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=priya_global
PG_USER=priya_admin
PG_PASSWORD=your_secure_password_here
PG_POOL_MIN=2
PG_POOL_MAX=20
PG_SSL_MODE=require

# ─────────────────────────────────────────────────────────────────────────────
# Redis Configuration
# ─────────────────────────────────────────────────────────────────────────────

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SSL=false

# ─────────────────────────────────────────────────────────────────────────────
# JWT Authentication (RS256)
# ─────────────────────────────────────────────────────────────────────────────

# Private key for signing tokens (PEM format)
JWT_SECRET_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAAKCAQEA...\n-----END RSA PRIVATE KEY-----

# Public key for verifying tokens (PEM format)
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8A...\n-----END PUBLIC KEY-----

JWT_ISSUER=priya-global
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# ─────────────────────────────────────────────────────────────────────────────
# AWS Configuration
# ─────────────────────────────────────────────────────────────────────────────

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=priya-global-media
S3_REGION=ap-south-1
SES_REGION=ap-south-1
COGNITO_POOL_ID=ap-south-1_xxxxx
COGNITO_CLIENT_ID=xxxxx

# ─────────────────────────────────────────────────────────────────────────────
# AI/LLM Configuration
# ─────────────────────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx
GOOGLE_AI_KEY=xxxxx
PRIMARY_LLM=claude-3-5-sonnet-20241022
SECONDARY_LLM=gpt-4o
TERTIARY_LLM=gemini-1.5-pro
COST_LLM=gpt-4o-mini

# ─────────────────────────────────────────────────────────────────────────────
# Platform Configuration
# ─────────────────────────────────────────────────────────────────────────────

ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
PLATFORM_NAME=Priya AI

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8000

# ─────────────────────────────────────────────────────────────────────────────
# Security Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Bcrypt rounds for password hashing (12 recommended for production)
BCRYPT_ROUNDS=12

# Max login attempts before lockout
MAX_LOGIN_ATTEMPTS=5

# Lockout duration in seconds (900 = 15 minutes)
LOCKOUT_DURATION=900

# Max concurrent sessions per user
SESSION_MAX_CONCURRENT=5

# Enable PII masking in logs
PII_MASKING_ENABLED=true

# ─────────────────────────────────────────────────────────────────────────────
# Rate Limiting (requests per minute)
# ─────────────────────────────────────────────────────────────────────────────

RATE_LIMIT_STARTER=100
RATE_LIMIT_GROWTH=500
RATE_LIMIT_ENTERPRISE=2000

# ─────────────────────────────────────────────────────────────────────────────
# Service Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Tenant Service runs on port 9002
# Do not change unless coordinating with Gateway (9000)

# ─────────────────────────────────────────────────────────────────────────────
# Feature Flags
# ─────────────────────────────────────────────────────────────────────────────

# Enable/disable features at platform level
ENABLE_ONBOARDING=true
ENABLE_CUSTOM_BRANDING=true
ENABLE_API_ACCESS=true
ENABLE_TEAM_MANAGEMENT=true

# ─────────────────────────────────────────────────────────────────────────────
# Notifications
# ─────────────────────────────────────────────────────────────────────────────

# Email for team invitations
NOTIFICATION_SERVICE_URL=http://localhost:9024
INVITATION_EMAIL_TEMPLATE=team_invite

# ─────────────────────────────────────────────────────────────────────────────
# Analytics & Monitoring
# ─────────────────────────────────────────────────────────────────────────────

# Enable analytics tracking
ANALYTICS_ENABLED=true

# Sentry error tracking (optional)
SENTRY_DSN=

# DataDog APM (optional)
DATADOG_ENABLED=false
DATADOG_SERVICE_NAME=priya-tenant
DATADOG_ENV=development
