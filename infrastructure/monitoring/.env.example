# ============================================================
# Priya Global Monitoring Stack Environment Configuration
# ============================================================
# Copy to .env and customize for your environment

# ─── Grafana ───
# IMPORTANT: Change this to a strong, unique password before deploying!
GRAFANA_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# ─── Prometheus ───
PROMETHEUS_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
PROMETHEUS_RETENTION_DAYS=30

# ─── AlertManager ───

# Slack Integration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# PagerDuty Integration
PAGERDUTY_SERVICE_KEY=your_pagerduty_service_key
PAGERDUTY_SECURITY_SERVICE_KEY=your_pagerduty_security_service_key

# OpsGenie Integration
OPSGENIE_API_KEY=your_opsgenie_api_key

# Email Integration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=alerts@priya-global.com
ALERT_EMAIL_TO=ops@priya-global.com

# ─── Exporters ───

# PostgreSQL Exporter
# IMPORTANT: Must match the PostgreSQL password set in main docker-compose.yml
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# Redis Exporter
REDIS_PASSWORD=

# ─── Data Retention ───
PROMETHEUS_RETENTION_TIME=30d
PROMETHEUS_RETENTION_SIZE=50GB

# ─── Resource Limits ───
PROMETHEUS_MEMORY_LIMIT=2g
PROMETHEUS_CPU_LIMIT=2
GRAFANA_MEMORY_LIMIT=1g
GRAFANA_CPU_LIMIT=1

# ─── TLS/SSL ───
ENABLE_TLS=false
TLS_CERT_PATH=/etc/prometheus/prometheus.crt
TLS_KEY_PATH=/etc/prometheus/prometheus.key

# ─── Logging ───
LOG_LEVEL=info
PROMETHEUS_LOG_LEVEL=info
GRAFANA_LOG_LEVEL=info
